# GateCHA Configuration
# Copy this file to .env and adjust values

# Server listen address
GATECHA_LISTEN_ADDR=:8080

# Database driver: sqlite or mysql (default: sqlite)
GATECHA_DB_DRIVER=sqlite

# Database DSN: file path for SQLite, or DSN string for MySQL
# SQLite example:  /app/data/gatecha.db
# MySQL example:   user:password@tcp(host:3306)/dbname?parseTime=true
GATECHA_DB_DSN=/app/data/gatecha.db

# Secret key for signing JWT tokens (min 32 chars, auto-generated if empty)
GATECHA_SECRET_KEY=

# Admin credentials (password auto-generated if empty, shown in logs)
GATECHA_ADMIN_USERNAME=admin
GATECHA_ADMIN_PASSWORD=

# Logging level: debug, info, warn, error
GATECHA_LOG_LEVEL=info

# Cleanup interval for expired challenges (in minutes)
GATECHA_CLEANUP_INTERVAL=10

# Set to true to allow CORS from any origin (default: per-key domain check)
GATECHA_CORS_ALLOW_ALL=false
